# Copy to .env.deploy and fill values
# cp .env.deploy.example .env.deploy

# Required
PROD_HOST=your.server.tld
# Aliases accepted by script: DEPLOY_HOST or ETHX_PROD_HOST

# Optional SSH settings
PROD_USER=root
PROD_PORT=22
# PROD_SSH_KEY=/home/you/.ssh/id_rsa
PROD_SSH_BATCH_MODE=false

# Optional deploy behavior
PROD_UPLOAD_DIR=/tmp/etherx-tauri
PROD_SERVICE_NAME=etherx-browser
PROD_SERVICE_USER=root
PROD_WORKING_DIR=/root
PROD_EXEC_START="/usr/bin/xvfb-run -a /usr/bin/etherx-browser"
PROD_INSTALL_SYSTEMD_UNIT=true
# Alias accepted by script: ETHX_SYSTEMD_SERVICE
# PROD_START_COMMAND="/usr/bin/etherx-browser --headless"
# PROD_POST_DEPLOY="echo deploy done"
INSTALL_WITH_SUDO=true
